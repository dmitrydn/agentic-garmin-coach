# Скопируй в .env и заполни значения
# cp .env.example .env

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── intervals.icu ──────────────────────────────────────────────────────────────
INTERVALS_ATHLETE_ID=i00000        # числовой ID из URL профиля
INTERVALS_API_KEY=                 # Settings → API

# ── Garmin Connect ─────────────────────────────────────────────────────────────
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ── Telegram ───────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                # от @BotFather
TELEGRAM_CHAT_ID=                  # ID чата (узнать через @userinfobot)
